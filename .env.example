# ============================================
# Symbiont Configuration
# Copy this file to .env and fill in your values
# ============================================

# --- Feishu (Lark) Integration ---
# Create a Feishu bot at https://open.feishu.cn/
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# --- Optional Feishu Settings ---
# Your Feishu open_id (for calendar features)
# FEISHU_OWNER_OPEN_ID=
# Chat ID for cron job notifications
# SYMBIONT_CRON_CHAT_ID=
# Bot display name (used in Feishu messages)
# SYMBIONT_BOT_NAME=Echo

# --- Dashboard ---
# Token for dashboard API authentication
SYMBIONT_DASHBOARD_TOKEN=your-secret-token

# --- Persona ---
# Directory name of your persona pack (default: persona-example)
# SYMBIONT_PERSONA_DIR=persona-example

# --- Advanced ---
# Debug logging (true/false)
# SYMBIONT_DEBUG=false
# CC communication mode (ws/print)
# SYMBIONT_CC_MODE=ws
# Path to Claude CLI binary
# CLAUDE_PATH=claude
# Embedding service URL (for memory vector search)
# EMBEDDING_URL=http://127.0.0.1:8000
